<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<!-- Main Content -->
<main class="main-content">
    <div class="container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb">
            <a href="/books"><i class="fas fa-home"></i> Books</a>
            <span class="breadcrumb-separator">/</span>
            <a href="/shelves"><i class="fas fa-layer-group"></i> Shelves</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current"><%= shelf.name %></span>
        </nav>

        <!-- Shelf Header -->
        <div class="shelf-header" style="--shelf-color: <%= shelf.color %>">
            <div class="shelf-header-icon" style="background-color: <%= shelf.color %>">
                <i class="fas fa-<%= shelf.icon %>"></i>
            </div>
            <div class="shelf-header-info">
                <h1 class="shelf-header-title"><%= shelf.name %></h1>
                <% if (shelf.description) { %>
                    <p class="shelf-header-description"><%= shelf.description %></p>
                <% } %>
                <div class="shelf-header-stats">
                    <span class="stat">
                        <i class="fas fa-book"></i>
                        <%= books.length %> book<%= books.length !== 1 ? 's' : '' %>
                    </span>
                    <span class="stat">
                        <i class="fas fa-calendar"></i>
                        Created <%= new Date(shelf.createdAt).toLocaleDateString() %>
                    </span>
                </div>
            </div>
            <div class="shelf-header-actions">
                <a href="/shelves/<%= shelf._id %>/edit" class="btn btn-secondary">
                    <i class="fas fa-edit"></i>
                    Edit Shelf
                </a>
                <form action="/shelves/<%= shelf._id %>?_method=DELETE" method="POST" class="delete-form-inline" onsubmit="return confirm('Are you sure you want to delete this shelf? Books will not be deleted.');">
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash"></i>
                        Delete
                    </button>
                </form>
            </div>
        </div>

        <!-- Books in Shelf -->
        <% if (books && books.length > 0) { %>
            <div class="books-grid">
                <% books.forEach(book => { %>
                    <article class="book-card">
                        <!-- Cover Image -->
                        <div class="book-cover">
                            <% if (book.coverImage) { %>
                                <img src="<%= book.coverImage %>" alt="<%= book.title %>">
                            <% } else { %>
                                <div class="book-cover-placeholder">
                                    <i class="fas fa-book"></i>
                                    <span><%= book.title.charAt(0).toUpperCase() %></span>
                                </div>
                            <% } %>
                            <div class="book-overlay">
                                <a href="/books/<%= book._id %>" class="btn btn-white">
                                    <i class="fas fa-eye"></i> View
                                </a>
                            </div>
                        </div>

                        <!-- Book Info -->
                        <div class="book-info">
                            <h3 class="book-title" title="<%= book.title %>">
                                <%= book.title %>
                            </h3>
                            <p class="book-author">
                                <i class="fas fa-user"></i>
                                <%= book.author %>
                            </p>
                            <% if (book.genre) { %>
                                <span class="book-genre">
                                    <i class="fas fa-tag"></i>
                                    <%= book.genre %>
                                </span>
                            <% } %>
                        </div>

                        <!-- Book Actions -->
                        <div class="book-actions">
                            <a href="/books/<%= book._id %>" class="btn btn-outline btn-sm" title="View Details">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a href="/books/<%= book._id %>/edit" class="btn btn-outline btn-sm" title="Edit Book">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form action="/shelves/<%= shelf._id %>/remove-book" method="POST" class="delete-form" title="Remove from Shelf">
                                <input type="hidden" name="bookId" value="<%= book._id %>">
                                <button type="submit" class="btn btn-warning btn-sm">
                                    <i class="fas fa-minus"></i>
                                </button>
                            </form>
                        </div>
                    </article>
                <% }) %>
            </div>
        <% } else { %>
            <!-- Empty State -->
            <div class="empty-state">
                <div class="empty-icon" style="background-color: <%= shelf.color %>">
                    <i class="fas fa-<%= shelf.icon %>"></i>
                </div>
                <h2>No Books in This Shelf</h2>
                <p>This shelf is empty. Add books to start building your collection.</p>
                <a href="/books" class="btn btn-primary btn-lg">
                    <i class="fas fa-plus"></i>
                    Browse Books to Add
                </a>
            </div>
        <% } %>

        <!-- Navigation -->
        <div class="book-navigation">
            <a href="/shelves" class="btn btn-outline">
                <i class="fas fa-arrow-left"></i>
                Back to All Shelves
            </a>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
