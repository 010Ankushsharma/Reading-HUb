<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<!-- Main Content -->
<main class="main-content">
    <div class="container">
        <!-- Page Header -->
        <div class="page-header">
            <div class="header-content">
                <h1 class="page-title">
                    <i class="fas fa-plus-circle"></i>
                    Add New Book
                </h1>
                <p class="page-subtitle">
                    Add a new book to your digital library
                </p>
            </div>
            <a href="/books" class="btn btn-outline">
                <i class="fas fa-arrow-left"></i>
                Back to Books
            </a>
        </div>

        <!-- Form Card -->
        <div class="form-card">
            <form action="/books" method="POST" enctype="multipart/form-data" class="book-form">
                <%- include('form', { book: book, errors: errors, shelves: shelves, isEdit: false }) %>
            </form>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
