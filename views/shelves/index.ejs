<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<!-- Main Content -->
<main class="main-content">
    <div class="container">
        <!-- Page Header -->
        <div class="page-header">
            <div class="header-content">
                <h1 class="page-title">
                    <i class="fas fa-layer-group"></i>
                    My Shelves
                </h1>
                <p class="page-subtitle">
                    Organize your books into collections
                </p>
            </div>
            <a href="/shelves/new" class="btn btn-primary btn-lg">
                <i class="fas fa-plus"></i>
                Create Shelf
            </a>
        </div>

        <!-- Shelves Grid -->
        <% if (shelves && shelves.length > 0) { %>
            <div class="shelves-grid">
                <% shelves.forEach(shelf => { %>
                    <article class="shelf-card" style="--shelf-color: <%= shelf.color %>">
                        <a href="/shelves/<%= shelf._id %>" class="shelf-link">
                            <div class="shelf-icon" style="background-color: <%= shelf.color %>">
                                <i class="fas fa-<%= shelf.icon %>"></i>
                            </div>
                            <div class="shelf-info">
                                <h3 class="shelf-name"><%= shelf.name %></h3>
                                <% if (shelf.description) { %>
                                    <p class="shelf-description"><%= shelf.description %></p>
                                <% } %>
                                <div class="shelf-stats">
                                    <span class="shelf-count">
                                        <i class="fas fa-book"></i>
                                        <%= shelf.bookCount %> book<%= shelf.bookCount !== 1 ? 's' : '' %>
                                    </span>
                                </div>
                            </div>
                        </a>
                        <div class="shelf-actions">
                            <a href="/shelves/<%= shelf._id %>/edit" class="btn btn-outline btn-sm" title="Edit Shelf">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form action="/shelves/<%= shelf._id %>?_method=DELETE" method="POST" class="delete-form" onsubmit="return confirm('Are you sure you want to delete this shelf? Books will not be deleted, only removed from this shelf.');">
                                <button type="submit" class="btn btn-danger btn-sm" title="Delete Shelf">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </article>
                <% }) %>
            </div>
        <% } else { %>
            <!-- Empty State -->
            <div class="empty-state">
                <div class="empty-icon" style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);">
                    <i class="fas fa-layer-group"></i>
                </div>
                <h2>No Shelves Yet</h2>
                <p>Create your first shelf to start organizing your books into collections.</p>
                <a href="/shelves/new" class="btn btn-primary btn-lg">
                    <i class="fas fa-plus"></i>
                    Create Your First Shelf
                </a>
            </div>
        <% } %>
    </div>
</main>

<%- include('../partials/footer') %>
