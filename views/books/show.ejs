<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<!-- Main Content -->
<main class="main-content">
    <div class="container">
        <!-- Breadcrumb -->
        <nav class="breadcrumb">
            <a href="/books"><i class="fas fa-home"></i> Books</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current"><%= book.title %></span>
        </nav>

        <!-- Book Details Header -->
        <div class="book-detail-header">
            <div class="book-detail-cover">
                <% if (book.coverImage) { %>
                    <img src="<%= book.coverImage %>" alt="<%= book.title %>">
                <% } else { %>
                    <div class="book-cover-placeholder large">
                        <i class="fas fa-book"></i>
                        <span><%= book.title.charAt(0).toUpperCase() %></span>
                    </div>
                <% } %>
            </div>

            <div class="book-detail-info">
                <h1 class="book-detail-title"><%= book.title %></h1>
                
                <div class="book-detail-meta">
                    <div class="meta-item">
                        <i class="fas fa-user"></i>
                        <span><strong>Author:</strong> <%= book.author %></span>
                    </div>
                    <% if (book.genre) { %>
                        <div class="meta-item">
                            <i class="fas fa-tag"></i>
                            <span><strong>Genre:</strong> <%= book.genre %></span>
                        </div>
                    <% } %>
                    <div class="meta-item">
                        <i class="fas fa-calendar"></i>
                        <span><strong>Added:</strong> <%= new Date(book.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                    </div>
                    <% if (book.downloadCount > 0) { %>
                        <div class="meta-item">
                            <i class="fas fa-download"></i>
                            <span><strong>Downloads:</strong> <%= book.downloadCount %></span>
                        </div>
                    <% } %>
                </div>

                <% if (book.description) { %>
                    <div class="book-detail-description">
                        <h3><i class="fas fa-align-left"></i> Description</h3>
                        <p><%= book.description %></p>
                    </div>
                <% } %>

                <!-- Action Buttons -->
                <div class="book-detail-actions">
                    <a href="/books/<%= book._id %>/download" class="btn btn-primary btn-lg">
                        <i class="fas fa-download"></i>
                        Download PDF
                    </a>
                    <a href="/books/<%= book._id %>/edit" class="btn btn-secondary btn-lg">
                        <i class="fas fa-edit"></i>
                        Edit Book
                    </a>
                    <form action="/books/<%= book._id %>?_method=DELETE" method="POST" class="delete-form-inline" onsubmit="return confirm('Are you sure you want to delete this book? This action cannot be undone.');">
                        <button type="submit" class="btn btn-danger btn-lg">
                            <i class="fas fa-trash"></i>
                            Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- PDF Preview Section -->
        <div class="pdf-preview-section">
            <div class="section-header">
                <h2><i class="fas fa-file-pdf"></i> PDF Preview</h2>
                <div class="pdf-controls">
                    <button class="btn btn-outline btn-sm" onclick="toggleFullscreen()">
                        <i class="fas fa-expand"></i>
                        Fullscreen
                    </button>
                </div>
            </div>
            
            <div class="pdf-container" id="pdfContainer">
                <iframe 
                    src="/uploads/<%= book.pdfFile %>" 
                    type="application/pdf"
                    class="pdf-viewer"
                    title="<%= book.title %> PDF"
                >
                    <p>Your browser does not support PDFs. 
                        <a href="/books/<%= book._id %>/download">Download the PDF</a> instead.
                    </p>
                </iframe>
            </div>
        </div>

        <!-- Navigation -->
        <div class="book-navigation">
            <a href="/books" class="btn btn-outline">
                <i class="fas fa-arrow-left"></i>
                Back to All Books
            </a>
        </div>
    </div>
</main>

<script>
    // Fullscreen toggle for PDF viewer
    function toggleFullscreen() {
        const container = document.getElementById('pdfContainer');
        if (!document.fullscreenElement) {
            container.requestFullscreen().catch(err => {
                console.error('Error attempting to enable fullscreen:', err);
            });
        } else {
            document.exitFullscreen();
        }
    }
</script>

<%- include('../partials/footer') %>
